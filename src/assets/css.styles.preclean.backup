}

/* Strong override for Meet the developer section */
.meet-developer,
.s-card.developer-card,
.s-card.developer-card .s-card-body,
.s-card.developer-card .developer__intro,
.s-card.developer-card .developer__intro *,
.s-card.developer-card .book-consult,
.s-card.developer-card .book-consult * {
  color: #ffffff !important;
}

/* Ensure the card sits above overlays */
.s-card.developer-card {
  position: relative !important;
  z-index: 99999 !important;
  visibility: visible !important;
  opacity: 1 !important;
  background: linear-gradient(180deg, rgba(0,0,0,0.28), rgba(0,0,0,0.18)) !important;
  box-shadow: 0 10px 40px rgba(0,0,0,0.55) !important;
}

/* Defensive: lower common site overlays when overlapping this card */
.s-card.developer-card ~ .hero-overlay,
.s-card.developer-card ~ .site-overlay,
.s-card.developer-card .hero-overlay,
.s-card.developer-card .site-overlay {
  z-index: 1 !important;
  mix-blend-mode: normal !important;
  pointer-events: none !important;
  background: transparent !important;
}

/* Remove transform/stacking traps inside this area */
.s-card.developer-card,
.s-card.developer-card * {
  transform: none !important;
  will-change: auto !important;
}

/* Text micro animation */
.meet-dev-copy {
  margin: 0 0 1rem;
  line-height: 1.6;
  color: #ffffff !important;
  transform-origin: center;
  will-change: transform, opacity;
}
.meet-dev-animate {
  animation: meetDevIn 700ms cubic-bezier(.2,.9,.2,1) both;
}
@keyframes meetDevIn {
  0% { opacity: 0; transform: translateY(8px) scale(0.998); }
  60% { opacity: 1; transform: translateY(-2px) scale(1.002); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}

/* CTA styling */
.book-consult {
  display: inline-block;
  padding: 0.6rem 1rem;
  border-radius: 999px;
  background: rgba(255,255,255,0.06);
  color: #fff !important;
  text-decoration: none;
  font-weight: 600;
  z-index: 4;
}

/* Orbit wrapper and path */
.orbit-wrapper {
  position: absolute;
  inset: -36px; /* space for orbit path */
  pointer-events: none;
  z-index: 2;
  display: block;
  transform: translateZ(0);
  --orbit-rot: 0deg; /* updated by JS */
}

/* subtle circular path visual */
.orbit-path {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  box-shadow: 0 0 40px rgba(138,43,226,0.06), inset 0 0 24px rgba(58,12,120,0.03);
  transform: translateZ(0);
}

/* the glowing orb that travels the path */
.orbit-orb {
  position: absolute;
  width: 18px;
  height: 18px;
  left: 50%;
  top: 0%;
  transform-origin: center calc(50% + 36px);
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(138,43,226,0.98), rgba(58,12,120,0.88));
  box-shadow: 0 0 28px rgba(138,43,226,0.55), 0 0 60px rgba(58,12,120,0.25);
  filter: blur(0.6px);
  /* position along circular path using CSS rotation variable */
  transform: rotate(var(--orbit-rot)) translateY(calc(-50% - 36px)) rotate(calc(-1 * var(--orbit-rot)));
  transition: transform 120ms linear;
}

/* slow orbit on hover */
  transition-duration: 400ms;
/* Respect reduced motion */
@media (prefers-reduced-motion: reduce) {
  .orbit-orb { transition: none !important; transform: translateY(calc(-50% - 36px)) !important; }
  .meet-dev-animate { animation: none !important; }
}

