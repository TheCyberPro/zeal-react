/* Ensure the content container sits above overlays and other stacking contexts */
.meet-developer .meet-dev-container {
  position: relative !important;
  z-index: 99999 !important;
  visibility: visible !important;
  opacity: 1 !important;
  /* optional: subtle backdrop so text reads clearly */
  background: linear-gradient(180deg, rgba(0,0,0,0.28), rgba(0,0,0,0.18)) !important;
  box-shadow: 0 10px 40px rgba(0,0,0,0.55) !important;
}

/* Keep the glow ring visually behind the content but above the page background */
.meet-developer .glow-ring {
  position: absolute !important;
  z-index: 99998 !important;
  pointer-events: none !important;
}

/* If there is a site-wide overlay element that covers sections, lower it when it overlaps this section.
   This targets common overlay class names; add any project-specific overlay classes if needed. */
.meet-developer ~ .hero-overlay,
.meet-developer ~ .site-overlay,
.meet-developer .hero-overlay,
.meet-developer .site-overlay {
  z-index: 1 !important;
  mix-blend-mode: normal !important;
  pointer-events: none !important;
  background: transparent !important;
}

