.meet-developer .hero-overlay,
.meet-developer .site-overlay {
  z-index: 1 !important;
  mix-blend-mode: normal !important;
  pointer-events: none !important;
  background: transparent !important;
}

.meet-developer,
.meet-developer * {
  transform: none !important;
  will-change: auto !important;
}

